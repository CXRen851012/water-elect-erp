rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 預設拒絕所有未授權之讀寫
    match /{document=**} {
      allow read, write: if false;
    }

    // 基礎安全認證輔助
    function isSignedIn() {
      return request.auth != null;
    }

    // 連線測試集合
    match /test/{id} {
      allow read, write: if true;
    }

    // 九大工務管理模組與備份設定安全同步規則
    
    match /workers/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /customers/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /suppliers/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /materials/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /projects/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /records/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /transactions/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /worker_advances/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /petty_cash/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /settings/{id} {
      allow get: if isSignedIn() && (id == request.auth.uid || resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && (id == request.auth.uid || resource.data.ownerUid == request.auth.uid);
      allow create, update: if isSignedIn() && (id == request.auth.uid || request.resource.data.ownerUid == request.auth.uid);
      allow delete: if isSignedIn() && (id == request.auth.uid || resource.data.ownerUid == request.auth.uid);
    }
    
    match /tombstones/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    match /backups/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}

